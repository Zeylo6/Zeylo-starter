rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Experience images: Anyone can read, only authenticated users can upload
    match /experience_images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default rule for other files
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
